# Stripe publishable key (safe in the browser). Get from https://dashboard.stripe.com/test/apikeys
# Or omit and set STRIPE_PUBLISHABLE_KEY in server/.env (dev: loaded via /api/stripe-config).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional: full API origin if you are not using the Vite dev proxy (default is same-origin /api)
# VITE_API_URL=http://localhost:5000
